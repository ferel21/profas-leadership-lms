# ==========================================
# PROFAS LEADERSHIP LMS - ENVIRONMENT VARIABLES
# ==========================================
# Gunakan file ini sebagai referensi untuk membuat .env atau .env.local
# JANGAN pernah mengunggah file .env asli (yang berisi kredensial rahasia) ke Git/GitHub.

# 1. DATABASE (SUPABASE POSTGRESQL)
# Untuk produksi (Vercel & Supabase), gunakan 2 URL berikut dari dasbor Supabase > Project Settings > Database > Connection String:
# - DATABASE_URL: Pilih mode "Transaction pooler" (Port 6543) - Sangat cepat untuk Serverless Vercel!
# - DIRECT_URL: Pilih mode "Session / Direct" (Port 5432) - Wajib untuk Prisma Migrate / Push skema!
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# 2. AUTENTIKASI (JWT & SESSION SECURITY)
# Rahasia untuk menandatangani JWT token cookie dan session (minimal 32 karakter acak)
# Bisa digenerate menggunakan: openssl rand -base64 32
JWT_SECRET="ganti-dengan-rahasia-jwt-yang-sangat-kuat-dan-panjang-untuk-produksi"
NEXTAUTH_SECRET="ganti-dengan-rahasia-nextauth-yang-sangat-kuat-untuk-produksi"

# URL Aplikasi (Untuk produksi, ganti ke domain Vercel Anda, contoh: https://profas-leadership-lms.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Direktori penyimpanan private pada deployment persistent (jangan gunakan /public)
PRIVATE_UPLOAD_DIR=".data/uploads"
# Token server-only untuk detail `/api/health` dari monitoring.
HEALTHCHECK_TOKEN="ganti-dengan-token-monitoring-acak"
# Pada Docker VPS, validasi startup mewajibkan token health yang kuat.
REQUIRE_HEALTHCHECK_TOKEN="true"
# Port host yang hanya di-bind ke localhost; Nginx menjadi public entrypoint.
APP_PORT="3000"

# 3. GOOGLE OAUTH 2.0
# Dapatkan di Google Cloud Console -> APIs & Services -> Credentials
# Wajib mendaftarkan Authorized Redirect URIs:
# - Lokal: http://localhost:3000/api/auth/callback/google
# - Produksi: https://profas-leadership-lms.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="ganti-dengan-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="ganti-dengan-google-client-secret"

# 3b. ASISTEN AI CLAUDE (opsional; fallback lokal tetap tersedia tanpa key)
# Simpan hanya di environment server/Vercel, jangan pernah expose sebagai NEXT_PUBLIC_*.
ANTHROPIC_API_KEY="sk-ant-ganti-dengan-api-key"

# 4. SUPABASE / OBJECT STORAGE (Opsi Produksi)
# Digunakan jika Anda menyimpan aset materi/video/avatar menggunakan Supabase Storage di produksi
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret-key"
