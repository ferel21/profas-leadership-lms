{
  "name": "profas-leadership-lms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H localhost -p 3000",
    "build": "prisma generate && prisma db push --accept-data-loss && prisma db seed && next build",
    "start": "next start",
    "smoke": "node scripts/smoke-test.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "autopilot:start": "bash scripts/autopilot-control.sh start 24",
    "autopilot:status": "bash scripts/autopilot-control.sh status",
    "autopilot:stop": "bash scripts/autopilot-control.sh stop",
    "autopilot:once": "bash scripts/autopilot-control.sh once",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "setup": "prisma generate && tsx prisma/init.ts && prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.2",
    "docx": "^9.7.1",
    "dotenv": "16.6.1",
    "html2canvas": "^1.4.1",
    "jose": "6.1.0",
    "jspdf": "^4.2.1",
    "lucide-react": "0.468.0",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "xlsx": "^0.18.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.18.6",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "better-sqlite3": "12.11.1",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.20",
    "prisma": "6.19.3",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
