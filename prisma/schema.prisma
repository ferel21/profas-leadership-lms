generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String              @id @default(cuid())
  name            String
  username        String?             @unique
  email           String              @unique
  passwordHash    String?
  authProvider    String              @default("LOCAL")
  role            Role                @default(STUDENT)
  persona         Persona?
  avatar          String?
  headline        String?
  phone           String?
  bio             String?
  organization    String?
  location        String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @default(now()) @updatedAt
  activityLogs    ActivityLog[]
  attempts        AssessmentAttempt[]
  attendances     AttendanceRecord[]
  certificates    Certificate[]
  mentoredCourses Course[]            @relation("CourseMentor")
  discussionPosts DiscussionPost[]
  enrollments     Enrollment[]
  eventAttendees  EventAttendee[]
  forumReplies    ForumReply[]
  forumThreads    ForumThread[]
  nodeProgress    NodeProgress[]
  notifications   Notification[]
  payments        Payment[]
  userBadges      UserBadge[]
  userSetting     UserSetting?
  xpLogs          XPLog[]

  @@index([role, persona])
}

model Course {
  id                   String          @id @default(cuid())
  slug                 String          @unique
  title                String
  shortDescription     String
  description          String
  category             String
  level                CourseLevel
  price                Int             @default(0)
  durationHours        Int
  rating               Float           @default(0)
  studentsCount        Int             @default(0)
  image                String
  certificateAvailable Boolean         @default(true)
  published            Boolean         @default(false)
  featured             Boolean         @default(false)
  outcomes             String
  mentorId             String
  createdAt            DateTime        @default(now())
  assessments          Assessment[]
  calendarEvents       CalendarEvent[]
  certificates         Certificate[]
  mentor               User            @relation("CourseMentor", fields: [mentorId], references: [id])
  nodes                CourseNode[]
  enrollments          Enrollment[]
  payments             Payment[]

  @@index([mentorId])
  @@index([published, featured])
}

model CourseNode {
  id              String           @id @default(cuid())
  courseId        String
  parentId        String?
  title           String
  description     String?
  type            NodeType
  order           Int
  durationMin     Int              @default(0)
  content         String?
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  assessmentId    String?
  assessment      Assessment?      @relation(fields: [assessmentId], references: [id])
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent          CourseNode?      @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children        CourseNode[]     @relation("NodeHierarchy")
  discussionPosts DiscussionPost[]
  progress        NodeProgress[]

  @@unique([courseId, parentId, order])
  @@index([courseId, type])
  @@index([parentId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model NodeProgress {
  id          String     @id @default(cuid())
  userId      String
  nodeId      String
  completedAt DateTime   @default(now())
  node        CourseNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([nodeId])
}

model Assessment {
  id           String               @id @default(cuid())
  courseId     String
  title        String
  type         AssessmentType
  isAssignment Boolean              @default(false)
  deadline     DateTime?
  passingScore Int                  @default(70)
  timeLimitMin Int                  @default(15)
  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts     AssessmentAttempt[]
  questions    AssessmentQuestion[]
  nodes        CourseNode[]

  @@index([courseId, type])
}

model AssessmentQuestion {
  id            String          @id @default(cuid())
  assessmentId  String
  type          QuestionType    @default(MULTIPLE_CHOICE)
  prompt        String
  options       String?
  correctAnswer String?
  points        Int             @default(10)
  explanation   String?
  order         Int
  assessment    Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]

  @@index([assessmentId, order])
}

model AssessmentAttempt {
  id           String          @id @default(cuid())
  userId       String
  assessmentId String
  status       AttemptStatus   @default(SUBMITTED)
  score        Int             @default(0)
  passed       Boolean         @default(false)
  feedback     String?
  submittedAt  DateTime        @default(now())
  gradedAt     DateTime?
  assessment   Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers      AttemptAnswer[]

  @@index([userId, passed, assessmentId])
  @@index([assessmentId, submittedAt])
}

model AttemptAnswer {
  id         String             @id @default(cuid())
  attemptId  String
  questionId String
  answerText String?
  fileUrl    String?
  score      Int?
  feedback   String?
  attempt    AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  status          EnrollmentStatus @default(ACTIVE)
  progressPercent Int              @default(0)
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, status])
  @@index([userId, status])
}

model Certificate {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  uniqueNumber String   @unique
  issuedAt     DateTime @default(now())
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model XPLog {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  source    String
  sourceId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, sourceId])
}

model DiscussionPost {
  id        String     @id @default(cuid())
  userId    String
  nodeId    String
  content   String
  createdAt DateTime   @default(now())
  node      CourseNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nodeId, createdAt])
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  courseId  String
  amount    Int
  method    String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  course    Course        @relation(fields: [courseId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([courseId, status])
}

model ForumCategory {
  id          String        @id @default(cuid())
  name        String
  description String?
  order       Int           @default(0)
  threads     ForumThread[]
}

model ForumThread {
  id         String        @id @default(cuid())
  categoryId String
  authorId   String
  title      String
  content    String
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  replies    ForumReply[]
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, pinned, createdAt])
}

model ForumReply {
  id        String      @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  createdAt DateTime    @default(now())
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model CalendarEvent {
  id                String             @id @default(cuid())
  title             String
  description       String?
  startTime         DateTime
  endTime           DateTime
  location          String?
  courseId          String?
  attendanceEnabled Boolean            @default(false)
  attendanceOpenAt  DateTime?
  attendanceCloseAt DateTime?
  createdAt         DateTime           @default(now())
  attendanceRecords AttendanceRecord[]
  course            Course?            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendees         EventAttendee[]
}

model EventAttendee {
  id      String        @id @default(cuid())
  eventId String
  userId  String
  status  String        @default("GOING")
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  eventId     String
  userId      String
  status      AttendanceStatus @default(PRESENT)
  checkedInAt DateTime?
  source      String           @default("SELF")
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  event       CalendarEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, status])
  @@index([eventId, status])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  imageUrl    String
  criteria    String
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserSetting {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences String
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MENTOR
  SUPER_ADMIN
}

enum Persona {
  STUDENT_ENTREPRENEUR
  ACADEMIC
  ORGANIZATION
  COOPERATIVE
}

enum CourseLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum AssessmentType {
  PRETEST
  MODULE
  FINAL
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED
  ABSENT
}

enum NodeType {
  FOLDER
  VIDEO
  PDF
  DOCUMENT
  IMAGE
  LINK
  QUIZ
  ASSIGNMENT
  TEXT
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  FILE_UPLOAD
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  PENDING_GRADE
  GRADED
}
