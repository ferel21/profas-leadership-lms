# ==========================================
# PROFAS LEADERSHIP LMS - ENVIRONMENT VARIABLES
# ==========================================
# Gunakan file ini sebagai referensi untuk membuat .env atau .env.local
# JANGAN pernah mengunggah file .env asli (yang berisi kredensial rahasia) ke Git/GitHub.

# 1. DATABASE
# Untuk lokal/development dapat menggunakan SQLite: "file:./dev.db"
# Untuk produksi (Vercel/Supabase/PostgreSQL): "postgresql://user:password@host:port/database?sslmode=require"
DATABASE_URL="file:./dev.db"

# 2. AUTENTIKASI (JWT & SESSION SECURITY)
# Rahasia untuk menandatangani JWT token cookie dan session (minimal 32 karakter acak)
# Bisa digenerate menggunakan: openssl rand -base64 32
JWT_SECRET="ganti-dengan-rahasia-jwt-yang-sangat-kuat-dan-panjang-untuk-produksi"
NEXTAUTH_SECRET="ganti-dengan-rahasia-nextauth-yang-sangat-kuat-untuk-produksi"

# URL Aplikasi (Untuk produksi, ganti ke domain Vercel Anda, contoh: https://profas-leadership-lms.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 3. GOOGLE OAUTH 2.0
# Dapatkan di Google Cloud Console -> APIs & Services -> Credentials
# Wajib mendaftarkan Authorized Redirect URIs:
# - Lokal: http://localhost:3000/api/auth/google/callback
# - Produksi: https://profas-leadership-lms.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID="ganti-dengan-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="ganti-dengan-google-client-secret"

# 4. SUPABASE / OBJECT STORAGE (Opsi Produksi)
# Digunakan jika Anda menyimpan aset materi/video/avatar menggunakan Supabase Storage di produksi
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret-key"
